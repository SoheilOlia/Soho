{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Soho Role Schema",
  "type": "object",
  "required": [
    "name",
    "version",
    "purpose",
    "when_to_use",
    "capabilities",
    "deliverables"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "when_to_use": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
